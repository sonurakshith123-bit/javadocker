pipeline {
    agent any

    stages {
        stage('installation maven') {
            steps {
              sh 'sudo dnf install maven -y'  
            }
        }
        stage('Build') {
            steps {
              sh 'mvn clean package'  
            }
        }
        stage('relese') {
            steps {
              archiveArtifacts artifacts: 'target/*.jar', followSymlinks: false  
            }
        }
    }
}
